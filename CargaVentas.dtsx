        <DTS:Executable
          DTS:refId="Package\SEQ Proceso ETL Ventas\Registrar estadisticas finales"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:DelayValidation="True"
          DTS:Description="Registrar estadisticas finales"
          DTS:DTSID="{6A65F1B1-80E7-4D0A-96DC-1E972CF12DC7}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Registrar estadisticas finales"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{1826EAED-2C79-4BFF-BAFF-B26657CD80FF}"
              SQLTask:SqlStatementSource="DECLARE @IdProceso int=(SELECT MAX(IdProceso) FROM dbo.LogProceso WHERE NombrePaquete='CargaVentas');&#xA;DECLARE @Inicio datetime=(SELECT FechaInicio FROM dbo.LogProceso WHERE IdProceso=@IdProceso);&#xA;DECLARE @Insertados int=(SELECT COUNT(*) FROM dbo.DimCliente WHERE FechaCarga&gt;=@Inicio)+(SELECT COUNT(*) FROM dbo.DimProducto WHERE FechaCarga&gt;=@Inicio)+(SELECT COUNT(*) FROM dbo.FactVentas WHERE FechaCarga&gt;=@Inicio);&#xA;DECLARE @Errores int=(SELECT COUNT(*) FROM dbo.LogErrores WHERE FechaError&gt;=@Inicio);&#xA;DECLARE @Leidos int=@Insertados+@Errores;&#xA;BEGIN TRY&#xA; SELECT @Leidos=(LEN(BulkColumn)-LEN(REPLACE(BulkColumn,CHAR(10),''))-1) FROM OPENROWSET(BULK 'C:\Unidad2\data\entrada\Clientes.csv',SINGLE_CLOB) C;&#xA; SELECT @Leidos=@Leidos+(LEN(BulkColumn)-LEN(REPLACE(BulkColumn,CHAR(10),''))-1) FROM OPENROWSET(BULK 'C:\Unidad2\data\entrada\Productos.csv',SINGLE_CLOB) P;&#xA; SELECT @Leidos=@Leidos+(LEN(BulkColumn)-LEN(REPLACE(BulkColumn,CHAR(10),''))-1) FROM OPENROWSET(BULK 'C:\Unidad2\data\entrada\Ventas.csv',SINGLE_CLOB) V;&#xA;END TRY BEGIN CATCH SET @Leidos=@Insertados+@Errores; END CATCH;&#xA;UPDATE dbo.LogProceso SET TotalLeidos=@Leidos,TotalInsertados=@Insertados,TotalErrores=@Errores,Mensaje='Carga terminada; pendiente archivado' WHERE IdProceso=@IdProceso;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\SEQ Proceso ETL Ventas\Registrar inicio en LogProceso"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:DelayValidation="True"
          DTS:Description="Registrar inicio en LogProceso"
          DTS:DTSID="{11834753-A18C-456A-9365-BC3844C8FD61}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Registrar inicio en LogProceso"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{1826EAED-2C79-4BFF-BAFF-B26657CD80FF}"
              SQLTask:SqlStatementSource="INSERT INTO dbo.LogProceso (NombrePaquete,FechaInicio,Estatus,Mensaje) VALUES ('CargaVentas',GETDATE(),'EN PROCESO','Archivos validados; inicia ETL');" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\SEQ Proceso ETL Ventas\Validar existencia de archivos"
          DTS:CreationName="Microsoft.SqlServer.Dts.Tasks.ExecuteProcess.ExecuteProcess, Microsoft.SqlServer.ExecProcTask, Version=17.100.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91"
          DTS:DelayValidation="True"
          DTS:Description="Validar existencia de archivos"
          DTS:DTSID="{02AB0075-F6CB-483D-8AD9-428CA70D2D6F}"
          DTS:ExecutableType="Microsoft.SqlServer.Dts.Tasks.ExecuteProcess.ExecuteProcess, Microsoft.SqlServer.ExecProcTask, Version=17.100.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91"
          DTS:LocaleID="-1"
          DTS:ObjectName="Validar existencia de archivos"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <ExecuteProcessData
              Executable="PowerShell.exe"
              Arguments="-NoProfile -ExecutionPolicy Bypass -Command &quot;&amp; { $f=@('C:\Unidad2\data\entrada\Clientes.csv','C:\Unidad2\data\entrada\Productos.csv','C:\Unidad2\data\entrada\Ventas.csv'); $m=@($f | Where-Object { -not (Test-Path -LiteralPath $_) }); if($m.Count -gt 0){ Write-Error ('Faltan archivos: ' + ($m -join ', ')); exit 2 } }&quot;"
              WorkingDirectory="C:\Unidad2" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
