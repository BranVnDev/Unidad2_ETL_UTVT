          DTS:ObjectName="Comprimir archivos procesados"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <ExecuteProcessData
              Executable="PowerShell.exe"
              Arguments="-NoProfile -ExecutionPolicy Bypass -Command &quot;&amp; { $s=Get-Date -Format 'yyyyMMdd_HHmmss'; $z=Join-Path 'C:\Unidad2\data\procesados' ('Procesados_'+$s+'.zip'); Compress-Archive -LiteralPath 'C:\Unidad2\data\procesados\Clientes.csv','C:\Unidad2\data\procesados\Productos.csv','C:\Unidad2\data\procesados\Ventas.csv' -DestinationPath $z -Force }&quot;"
              WorkingDirectory="C:\Unidad2" />
          </DTS:ObjectData>
        </DTS:Executable>
