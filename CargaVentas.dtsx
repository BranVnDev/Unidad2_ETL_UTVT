          DTS:ObjectName="Fin - registrar estatus completado"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{1826EAED-2C79-4BFF-BAFF-B26657CD80FF}"
              SQLTask:SqlStatementSource="DECLARE @Id int=(SELECT MAX(IdProceso) FROM dbo.LogProceso WHERE NombrePaquete='CargaVentas'); UPDATE dbo.LogProceso SET FechaFin=GETDATE(),DuracionSegundos=DATEDIFF(SECOND,FechaInicio,GETDATE()),Estatus='COMPLETADO',Mensaje='ETL, movimiento y compresion completados' WHERE IdProceso=@Id;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
